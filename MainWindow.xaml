<Window x:Class="GuardioChatbot.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:GuardioChatbot"
        mc:Ignorable="d"
        Title="Guardio Cybersecurity Assistant"
        Height="720" 
        Width="580"
        WindowStartupLocation="CenterScreen"
        ResizeMode="NoResize"
        Background="#0B1120">


    <Grid> 
       

        <!-- ========================= WELCOME GRID ========================= -->

        <Grid Name="WelcomeGrid">

            <!-- Background Gradient -->
            <Grid.Background>
                <LinearGradientBrush StartPoint="0,0"
                                     EndPoint="1,1">
                    <GradientStop Color="#0F172A"
                                  Offset="0"/>
                    <GradientStop Color="#111827"
                                  Offset="1"/>
                </LinearGradientBrush>
            </Grid.Background>

            <!-- Decorative Circles -->
            <Ellipse Width="300"
                     Height="300"
                     Fill="#1E293B"
                     Opacity="0.3"
                     HorizontalAlignment="Left"
                     VerticalAlignment="Top"
                     Margin="-120,-120,0,0"/>

            <Ellipse Width="250"
                     Height="250"
                     Fill="#22C55E"
                     Opacity="0.1"
                     HorizontalAlignment="Right"
                     VerticalAlignment="Bottom"
                     Margin="0,0,-100,-100"/>

            <StackPanel VerticalAlignment="Center"
                        HorizontalAlignment="Center">

                <!-- Logo -->
                <Border Width="150"
                        Height="150"
                        CornerRadius="75"
                        Background="#111827"
                        BorderBrush="#22C55E"
                        BorderThickness="3">

                    <Image Source="logo.png"
                           Stretch="Uniform"/>
                </Border>

                <!-- Main Title -->
                <TextBlock Text="GUARDIO"
                           FontSize="46"
                           FontWeight="Bold"
                           Foreground="White"
                           HorizontalAlignment="Center"
                           Margin="0,25,0,0"/>

                <!-- Subtitle -->
                <TextBlock Text="Cybersecurity Awareness Assistant"
                           FontSize="18"
                           Foreground="#CBD5E1"
                           HorizontalAlignment="Center"
                           Margin="0,10"/>

                <!-- Description -->
                <TextBlock Text="Protecting You From Online Threats"
                           FontSize="14"
                           Foreground="#94A3B8"
                           HorizontalAlignment="Center"/>

                <!-- Divider -->
                <Rectangle Width="250"
                           Height="2"
                           Fill="#22C55E"
                           Margin="0,25"/>

                <!-- Start Button -->
                <Button Content="START CHAT"
                        Width="240"
                        Height="55"
                        FontWeight="Bold"
                        FontSize="17"
                        Cursor="Hand"
                        Background="#22C55E"
                        Foreground="White"
                        BorderThickness="0"
                        Click="StartButton_Click">

                    <Button.Style>
                        <Style TargetType="Button">
                            <Setter Property="Template">
                                <Setter.Value>
                                    <ControlTemplate TargetType="Button">
                                        <Border Background="{TemplateBinding Background}"
                                                CornerRadius="15">
                                            <ContentPresenter HorizontalAlignment="Center"
                                                              VerticalAlignment="Center"/>
                                        </Border>
                                    </ControlTemplate>
                                </Setter.Value>
                            </Setter>
                        </Style>
                    </Button.Style>
                </Button>
            </StackPanel>
        </Grid>

        <!-- ========================= USERNAME GRID ========================= -->

        <Grid Name="UsernameGrid"
              Visibility="Collapsed">

            <!-- Background -->
            <Grid.Background>
                <LinearGradientBrush StartPoint="0,0"
                                     EndPoint="1,1">
                    <GradientStop Color="#0F172A"
                                  Offset="0"/>
                    <GradientStop Color="#111827"
                                  Offset="1"/>
                </LinearGradientBrush>
            </Grid.Background>

            <!-- Card -->
            <Border Width="420"
                    Height="380"
                    Background="#111827"
                    CornerRadius="25"
                    BorderBrush="#1E293B"
                    BorderThickness="2"
                    Padding="25"
                    HorizontalAlignment="Center"
                    VerticalAlignment="Center">

                <StackPanel>

                    <!-- Icon -->
                    <TextBlock Text="👤"
                               FontSize="50"
                               HorizontalAlignment="Center"/>

                    <!-- Heading -->
                    <TextBlock Text="WELCOME USER"
                               FontSize="28"
                               FontWeight="Bold"
                               Foreground="White"
                               HorizontalAlignment="Center"
                               Margin="0,10"/>

                    <!-- Subheading -->
                    <TextBlock Text="Please enter your username to continue"
                               FontSize="15"
                               Foreground="#94A3B8"
                               HorizontalAlignment="Center"
                               Margin="0,0,0,25"/>

                    <!-- Textbox Border -->
                    <Border CornerRadius="12"
                            Background="#1E293B"
                            Padding="5">

                        <TextBox Name="NameInputBox"
                                 Height="45"
                                 FontSize="16"
                                 Padding="10"
                                 BorderThickness="0"
                                 Background="Transparent"
                                 Foreground="White"/>
                    </Border>

                    <!-- Validation -->
                    <TextBlock Name="ValidationMessage"
                               Foreground="#EF4444"
                               FontSize="14"
                               Margin="5,10"
                               TextAlignment="Center"/>

                    <!-- Continue Button -->
                    <Button Content="CONTINUE"
                            Height="50"
                            Margin="0,25,0,0"
                            FontSize="16"
                            FontWeight="Bold"
                            Cursor="Hand"
                            Background="#3B82F6"
                            Foreground="White"
                            BorderThickness="0"
                            Click="ContinueButton_Click">

                        <Button.Style>
                            <Style TargetType="Button">
                                <Setter Property="Template">
                                    <Setter.Value>
                                        <ControlTemplate TargetType="Button">
                                            <Border Background="{TemplateBinding Background}"
                                                    CornerRadius="15">
                                                <ContentPresenter HorizontalAlignment="Center"
                                                                  VerticalAlignment="Center"/>
                                            </Border>
                                        </ControlTemplate>
                                    </Setter.Value>
                                </Setter>
                            </Style>
                        </Button.Style>
                    </Button>
                </StackPanel>
            </Border>
        </Grid>

        <!-- ========================= CHATBOT GRID ========================= -->

        <Grid Name="ChatbotGrid"
              Visibility="Collapsed"
              Margin="12">

            <Grid.RowDefinitions>
                <RowDefinition Height="90"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="85"/>
            </Grid.RowDefinitions>

            <!-- ================= HEADER ================= -->

            <Border Grid.Row="0"
                    Background="#111827"
                    CornerRadius="20"
                    Padding="15"
                    BorderBrush="#1E293B"
                    BorderThickness="2">

                <DockPanel>

                    <!-- Logo -->
                    <Border Width="55"
                            Height="55"
                            CornerRadius="28"
                            Background="#1E293B"
                            BorderBrush="#22C55E"
                            BorderThickness="2">

                        <Image Source="logo.png"
                               Stretch="Uniform"/>
                    </Border>

                    <!-- Text -->
                    <StackPanel Margin="15,0">

                        <TextBlock Text="GUARDIO"
                                   FontSize="26"
                                   FontWeight="Bold"
                                   Foreground="White"/>

                        <TextBlock Text="Cybersecurity Protection Assistant"
                                   FontSize="14"
                                   Foreground="#94A3B8"/>
                    </StackPanel>

                    <!-- Status -->
                    <Border Background="#14532D"
                            CornerRadius="10"
                            Padding="10,5"
                            HorizontalAlignment="Right"
                            DockPanel.Dock="Right"
                            VerticalAlignment="Center">

                        <TextBlock Text="● ONLINE"
                                   Foreground="#86EFAC"
                                   FontWeight="Bold"/>
                    </Border>
                </DockPanel>
            </Border>

            <!-- ================= CHAT AREA ================= -->

            <Border Grid.Row="1"
                    Margin="0,12"
                    Background="#111827"
                    CornerRadius="20"
                    BorderBrush="#1E293B"
                    BorderThickness="2">

                <RichTextBox Name="ChatBox"
                             Background="Transparent"
                             Foreground="White"
                             BorderThickness="0"
                             Padding="15"
                             FontSize="14"
                             IsReadOnly="True"
                             VerticalScrollBarVisibility="Auto"/>
            </Border>

            <!-- ================= INPUT AREA ================= -->

            <Border Grid.Row="2"
                    Background="#111827"
                    CornerRadius="20"
                    Padding="12"
                    BorderBrush="#1E293B"
                    BorderThickness="2">

                <Grid>

                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="130"/>
                    </Grid.ColumnDefinitions>

                    <!-- Input -->
                    <Border Background="#1E293B"
                            CornerRadius="15"
                            Padding="5"
                            Margin="0,0,10,0">

                        <TextBox Name="InputBox"
                                 FontSize="15"
                                 Padding="10"
                                 BorderThickness="0"
                                 Background="Transparent"
                                 Foreground="White"
                                 KeyDown="InputBox_KeyDown"/>
                    </Border>

                    <!-- Send Button -->
                    <Button Name="SendButton"
                            Grid.Column="1"
                            Content="SEND"
                            FontWeight="Bold"
                            FontSize="15"
                            Cursor="Hand"
                            Background="#22C55E"
                            Foreground="White"
                            BorderThickness="0"
                            Click="SendButton_Click">

                        <Button.Style>
                            <Style TargetType="Button">
                                <Setter Property="Template">
                                    <Setter.Value>
                                        <ControlTemplate TargetType="Button">
                                            <Border Background="{TemplateBinding Background}"
                                                    CornerRadius="15">
                                                <ContentPresenter HorizontalAlignment="Center"
                                                                  VerticalAlignment="Center"/>
                                            </Border>
                                        </ControlTemplate>
                                    </Setter.Value>
                                </Setter>
                            </Style>
                        </Button.Style>
                    </Button>
                </Grid>
            </Border>
        </Grid>
    </Grid>
</Window>